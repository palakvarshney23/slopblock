# Dependencies
node_modules/

# Build output
dist/

# Electron build artifacts
out/

# CA certificates generated at runtime
certs/

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# IDE / editor
.vscode/
.idea/

# Claude Code session data
.claude/
.agents/
skills-lock.json

