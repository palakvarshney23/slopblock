cache/

# Python bytecode
__pycache__/
*.py[cod]

# Chrome-generated when loading unpacked extension locally
extension/_metadata/

# Packaged extension zip (build artifact)
*.zip

# User app data written at runtime
config.json
counts.json
settings.json

# Tests and evaluation scripts
test/
__mocks__/
jest.config.js
eval/

# Landing page lives in its own repo (slopblock-website)
landing-page/

seo/