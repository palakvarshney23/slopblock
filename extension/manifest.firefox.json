{
  "manifest_version": 3,
  "name": "SlopBlock",
  "version": "1.0.0",
  "description": "Detects and hides AI-generated text, images, and YouTube videos as you browse. All processing stays on your machine.",
  "browser_specific_settings": {
    "gecko": {
      "id": "slopblock@localhost",
      "strict_min_version": "109.0"
    }
  },
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:8083/*"
  ],
  "icons": {
    "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com/*",
        "*://*.amazon.co.uk/*",
        "*://*.amazon.de/*",
        "*://*.amazon.ca/*",
        "*://*.amazon.in/*",
        "https://www.ebay.com/*",
        "https://www.ebay.co.uk/*"
      ],
      "js": ["marketplace-sites.js", "marketplace.js"],
      "css": ["marketplace.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://github.com/*"],
      "js": ["github-pr.js"],
      "css": ["github-pr.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SlopBlock",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
